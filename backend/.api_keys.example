# SuperBrain API Keys
# Copy this file to .api_keys (same directory) and fill in your keys.
# .api_keys is gitignored — never commit your actual keys.
#
# Get free API keys at:
#   Groq        → https://console.groq.com/keys
#   Gemini      → https://aistudio.google.com/apikey
#   OpenRouter  → https://openrouter.ai/keys
#
# You don't need all three — the router falls back automatically.
# Recommended: add at least Gemini (most generous free tier).
# Local Ollama is always available as the last resort (no key needed).

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
